# Google Gemini API key (used by Cloudflare Worker proxy, not the client)
GEMINI_API_KEY=

# Cloudflare Turnstile keys
# For local dev, use Turnstile test keys: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# Site key "1x00000000000000000000AA" always passes, secret key "1x0000000000000000000000000000000AA" always passes
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
VITE_TURNSTILE_SITE_KEY=

# API URL for the Cloudflare Worker proxy
VITE_API_URL=
